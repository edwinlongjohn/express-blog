 <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div
                class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden animate-on-scroll">

                <div class="px-6 py-8 sm:p-10">
                    <div class="mb-8 border-b border-slate-100 pb-8">
                        <h1 class="text-3xl font-extrabold text-slate-900 font-['Merriweather']">Create New Article</h1>
                        <p class="mt-2 text-sm text-slate-500">Draft a new post to share with your audience.</p>
                    </div>

                                <form action="/create-post" method="POST" class="space-y-8">

                        <!-- Title -->
                        <div>
                            <label for="title" class="block text-sm font-semibold text-slate-700 mb-2">Post Title <span
                                    class="text-red-500">*</span></label>
                            <input type="text" name="title" id="title"
                                class="block w-full border-0 border-b-2 border-slate-200 bg-transparent px-0 py-3 text-2xl font-bold placeholder-slate-300 focus:border-indigo-600 focus:ring-0 transition-colors"
                                placeholder="e.g., The Future of Web Dev" required>
                        </div>

                        <div class="grid grid-cols-1 gap-y-6 lg:grid-cols-2 lg:gap-x-8">
                            <!-- Category -->
                            <div>
                                <label for="category_id"
                                    class="block text-sm font-semibold text-slate-700 mb-2">Category</label>
                                <div class="relative">
                                    <select id="category_id" name="category_id" required
                                        class="block w-full appearance-none rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 sm:text-sm transition-all text-base">
                                        <option value="" disabled selected>Select a category</option>
                                        <% (categories || []).forEach((category) => { %>
                                            <option value="<%= category.slug %>"><%= category.name %></option>
                                        <% }) %>
                                    </select>
                                    <div
                                        class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500">
                                        <i class="fas fa-chevron-down text-sm"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Publish Status -->
                            <div>
                                <label for="status"
                                    class="block text-sm font-semibold text-slate-700 mb-2">Status</label>
                                <div class="relative">
                                    <select id="status" name="status"
                                        class="block w-full appearance-none rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 sm:text-sm transition-all text-base">
                                        <option value="draft">Draft</option>
                                        <option value="published">Published</option>
                                        <option value="archived">Archived</option>
                                    </select>
                                    <div
                                        class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500">
                                        <i class="fas fa-chevron-down text-sm"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Featured Image Upload -->
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-2">Featured Image</label>
                            <div
                                class="mt-1 flex justify-center rounded-2xl border-2 border-dashed border-slate-300 px-6 pt-10 pb-12 hover:border-indigo-400 hover:bg-indigo-50/50 transition-colors group cursor-pointer relative">
                                <div class="space-y-1 text-center">
                                    <div
                                        class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-slate-100 group-hover:bg-indigo-100 mb-4 transition-colors">
                                        <i class="fas fa-image text-2xl text-slate-400 group-hover:text-indigo-600"></i>
                                    </div>
                                    <div class="flex text-sm justify-center text-slate-600">
                                        <label for="file-upload"
                                            class="relative cursor-pointer rounded-md bg-transparent font-medium text-indigo-600 focus-within:outline-none hover:text-indigo-500">
                                            <span>Upload a file</span>
                                            <input id="file-upload" name="file-upload" type="file" class="sr-only"
                                                accept="image/*">
                                        </label>
                                        <p class="pl-1">or drag and drop</p>
                                    </div>
                                    <p class="text-xs text-slate-500">PNG, JPG, GIF up to 10MB</p>
                                </div>
                            </div>
                        </div>

                        <!-- Content Editor -->
                        <div>
                            <label for="content" class="block text-sm font-semibold text-slate-700 mb-2">Article Content
                                <span class="text-red-500">*</span></label>
                            <div
                                class="border border-slate-200 rounded-xl overflow-hidden focus-within:border-indigo-500 focus-within:ring-2 focus-within:ring-indigo-500/20 transition-all bg-white">
                                <!-- Mock Toolbar -->
                                <div
                                    class="flex items-center space-x-1 border-b border-slate-200 bg-slate-50 px-3 py-2 text-slate-500 overflow-x-auto">
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Bold"><i class="fas fa-bold"></i></button>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Italic"><i class="fas fa-italic"></i></button>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Underline"><i class="fas fa-underline"></i></button>
                                    <div class="w-px h-6 bg-slate-300 mx-2"></div>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Heading 1"><i class="fas fa-heading"></i><sub
                                            class="text-xs ml-0.5">1</sub></button>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Heading 2"><i class="fas fa-heading"></i><sub
                                            class="text-xs ml-0.5">2</sub></button>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Quote"><i class="fas fa-quote-right"></i></button>
                                    <div class="w-px h-6 bg-slate-300 mx-2"></div>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Link"><i class="fas fa-link"></i></button>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Image"><i class="far fa-image"></i></button>
                                    <button type="button"
                                        class="p-2 rounded hover:bg-slate-200 hover:text-slate-900 transition-colors"
                                        title="Code"><i class="fas fa-code"></i></button>
                                </div>

                                <textarea id="content" name="content" rows="15"
                                    class="block w-full border-0 focus:ring-0 p-4 text-base placeholder-slate-400 resize-y"
                                    placeholder="Start writing your amazing article here..."></textarea>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center justify-end space-x-4 pt-6 border-t border-slate-100">
                            <a href="/posts"
                                class="px-6 py-3 border border-slate-300 shadow-sm text-base font-medium rounded-full text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                                Cancel
                            </a>
                            <button type="submit"
                                class="inline-flex justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full shadow-lg shadow-indigo-500/30 text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transform transition-all hover:-translate-y-0.5">
                                Publish Article
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>