<%- include('partials/header.ejs') %>
<body class="bg-slate-50 text-slate-900 antialiased selection:bg-indigo-200 selection:text-indigo-900 overflow-x-hidden">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass transition-all duration-300 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex-shrink-0 flex items-center gap-2">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-500 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-indigo-500/30">
                        L
                    </div>
                    <a href="/" class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600 font-['Merriweather'] tracking-tight">Lee's Blog</a>
                </div>
                <div class="hidden md:ml-6 md:flex md:space-x-8 items-center">
                    <a href="/" class="text-indigo-600 font-medium px-3 py-2 text-sm transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:rounded-full">Home</a>
                    <a href="posts.html" class="text-slate-600 hover:text-indigo-600 font-medium px-3 py-2 text-sm transition-colors">Articles</a>
                    <a href="#about" class="text-slate-600 hover:text-indigo-600 font-medium px-3 py-2 text-sm transition-colors">About</a>
                    <a href="create-post.html" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-full text-sm font-medium transition-all shadow-md shadow-indigo-500/20 hover:shadow-lg hover:shadow-indigo-500/40 transform hover:-translate-y-0.5">Write</a>
                </div>
                <!-- Mobile menu button -->
                <div class="-mr-2 flex items-center md:hidden">
                    <button id="mobile-menu-button" type="button" class="inline-flex items-center justify-center p-2 rounded-md text-slate-400 hover:text-slate-500 hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500" aria-controls="mobile-menu" aria-expanded="false">
                        <span class="sr-only">Open main menu</span>
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile menu -->
        <div class="md:hidden hidden bg-white border-t border-slate-100 shadow-xl absolute w-full" id="mobile-menu">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <a href="index.html" class="bg-indigo-50 text-indigo-600 block px-3 py-2 rounded-md text-base font-medium">Home</a>
                <a href="posts.html" class="text-slate-600 hover:bg-slate-50 hover:text-slate-900 block px-3 py-2 rounded-md text-base font-medium">Articles</a>
                <a href="#about" class="text-slate-600 hover:bg-slate-50 hover:text-slate-900 block px-3 py-2 rounded-md text-base font-medium">About</a>
                <a href="create-post.html" class="text-indigo-600 hover:bg-indigo-50 block px-3 py-2 rounded-md text-base font-medium mt-4">Write a Post</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-slate-50">
        <!-- Background Blobs -->
        <div class="absolute top-0 -left-4 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"></div>
        <div class="absolute top-0 -right-4 w-72 h-72 bg-yellow-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-8 left-20 w-72 h-72 bg-pink-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-4000"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center animate-on-scroll">
            <span class="inline-block py-1 px-3 rounded-full bg-indigo-100 text-indigo-700 text-sm font-semibold mb-6 tracking-wide uppercase shadow-sm border border-indigo-200">Welcome to My Corner of the Web</span>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-6 drop-shadow-sm">
                Stories, thoughts, and <br class="hidden md:block" />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500">ideas that matter.</span>
            </h1>
            <p class="mt-4 max-w-2xl text-xl text-slate-600 mx-auto font-light leading-relaxed mb-10">
                Explore a curated collection of essays on design, technology, and life. Dive in and discover perspectives that inspire and provoke thought.
            </p>
            <div class="flex justify-center gap-4 flex-col sm:flex-row">
                <a href="#featured" class="px-8 py-4 border border-transparent text-lg font-medium rounded-full text-white bg-indigo-600 hover:bg-indigo-700 md:text-lg transition-all shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50 hover:-translate-y-1">
                    Read the Blog
                </a>
                <a href="#newsletter" class="px-8 py-4 border-2 border-slate-200 text-lg font-medium rounded-full text-slate-700 bg-white hover:border-indigo-200 hover:bg-slate-50 md:text-lg transition-all hover:-translate-y-1">
                    Subscribe
                </a>
            </div>
        </div>
        
        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 flex flex-col items-center animate-bounce text-slate-400">
            <span class="text-sm font-medium mb-2">Scroll</span>
            <i class="fas fa-arrow-down"></i>
        </div>
    </div>

    <!-- Featured Posts Section -->
    <section id="featured" class="py-24 bg-white relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 animate-on-scroll">
                <h2 class="text-base text-indigo-600 font-semibold tracking-wide uppercase">Latest Additions</h2>
                <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-slate-900 sm:text-4xl">Featured Articles</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                <!-- Post Card 1 -->
                <article class="flex flex-col bg-white rounded-2xl overflow-hidden border border-slate-100 card-hover animate-on-scroll delay-100">
                    <div class="flex-shrink-0 relative overflow-hidden group">
                        <img class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1496128858413-b36217c2ce36?ixlib=rb-1.2.1&auto=format&fit=crop&w=1679&q=80" alt="Desk setup">
                        <div class="absolute top-4 left-4">
                            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-white/90 text-indigo-800 backdrop-blur-sm shadow-sm">
                                Technology
                            </span>
                        </div>
                    </div>
                    <div class="flex-1 p-6 flex flex-col justify-between">
                        <div class="flex-1">
                            <a href="#" class="block mt-2">
                                <h3 class="text-xl font-bold text-slate-900 hover:text-indigo-600 transition-colors line-clamp-2">
                                    The Future of Modern Web Development
                                </h3>
                                <p class="mt-3 text-base text-slate-500 line-clamp-3">
                                    Exploring the shift towards edge computing, modern frameworks, and how static sites are becoming dynamic powerhouses.
                                </p>
                            </a>
                        </div>
                        <div class="mt-6 flex items-center">
                            <div class="flex-shrink-0">
                                <img class="h-10 w-10 rounded-full border-2 border-white shadow-sm" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Lee">
                            </div>
                            <div class="ml-3">
                                <p class="text-sm font-medium text-slate-900">
                                    Lee Anderson
                                </p>
                                <div class="flex space-x-1 text-sm text-slate-500">
                                    <time datetime="2024-03-16">Mar 16, 2026</time>
                                    <span aria-hidden="true">&middot;</span>
                                    <span>6 min read</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- Post Card 2 -->
                <article class="flex flex-col bg-white rounded-2xl overflow-hidden border border-slate-100 card-hover animate-on-scroll delay-200">
                    <div class="flex-shrink-0 relative overflow-hidden group">
                        <img class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1547586696-ea22b4d4235d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1679&q=80" alt="Abstract UX">
                        <div class="absolute top-4 left-4">
                            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-white/90 text-pink-800 backdrop-blur-sm shadow-sm">
                                Design
                            </span>
                        </div>
                    </div>
                    <div class="flex-1 p-6 flex flex-col justify-between">
                        <div class="flex-1">
                            <a href="#" class="block mt-2">
                                <h3 class="text-xl font-bold text-slate-900 hover:text-indigo-600 transition-colors line-clamp-2">
                                    Creating Intuitive User Interfaces
                                </h3>
                                <p class="mt-3 text-base text-slate-500 line-clamp-3">
                                    Why less is more when it comes to UI design. A deep dive into spacing, typography, and micro-interactions that delight users.
                                </p>
                            </a>
                        </div>
                        <div class="mt-6 flex items-center">
                            <div class="flex-shrink-0">
                                <img class="h-10 w-10 rounded-full border-2 border-white shadow-sm" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Lee">
                            </div>
                            <div class="ml-3">
                                <p class="text-sm font-medium text-slate-900">
                                    Lee Anderson
                                </p>
                                <div class="flex space-x-1 text-sm text-slate-500">
                                    <time datetime="2024-03-10">Mar 10, 2026</time>
                                    <span aria-hidden="true">&middot;</span>
                                    <span>4 min read</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>

                <!-- Post Card 3 -->
                <article class="flex flex-col bg-white rounded-2xl overflow-hidden border border-slate-100 card-hover animate-on-scroll delay-300">
                    <div class="flex-shrink-0 relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent z-10"></div>
                        <img class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1550439062-609e1531270e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1679&q=80" alt="Coding">
                        <div class="absolute top-4 left-4 z-20">
                            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-white/90 text-purple-800 backdrop-blur-sm shadow-sm">
                                Productivity
                            </span>
                        </div>
                        <div class="absolute bottom-4 left-4 z-20">
                             <span class="text-white text-sm font-medium"><i class="fas fa-star text-yellow-400 mr-1"></i> Editor's Pick</span>
                        </div>
                    </div>
                    <div class="flex-1 p-6 flex flex-col justify-between">
                        <div class="flex-1">
                            <a href="#" class="block mt-2">
                                <h3 class="text-xl font-bold text-slate-900 hover:text-indigo-600 transition-colors line-clamp-2">
                                    Finding Flow in a Hyperconnected World
                                </h3>
                                <p class="mt-3 text-base text-slate-500 line-clamp-3">
                                    Strategies to disconnect, focus deeply, and produce your best work without falling victim to constant notifications.
                                </p>
                            </a>
                        </div>
                        <div class="mt-6 flex items-center">
                            <div class="flex-shrink-0">
                                <img class="h-10 w-10 rounded-full border-2 border-white shadow-sm" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Lee">
                            </div>
                            <div class="ml-3">
                                <p class="text-sm font-medium text-slate-900">
                                    Lee Anderson
                                </p>
                                <div class="flex space-x-1 text-sm text-slate-500">
                                    <time datetime="2024-03-05">Mar 5, 2026</time>
                                    <span aria-hidden="true">&middot;</span>
                                    <span>8 min read</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <!-- View More Button -->
            <div class="mt-16 text-center animate-on-scroll">
                <a href="posts.html" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full text-indigo-700 bg-indigo-50 hover:bg-indigo-100 hover:scale-105 transition-all w-full sm:w-auto">
                    View All Articles
                    <i class="fas fa-arrow-right ml-2 text-sm"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-24 bg-slate-50 border-y border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
                <div class="animate-on-scroll">
                    <h2 class="text-3xl font-extrabold text-slate-900 sm:text-4xl mb-6">Hello, I'm Lee.</h2>
                    <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                        I'm a writer, developer, and design enthusiast. I created this space to share my journey, the lessons I've learned, and the ideas that keep me awake at night.
                    </p>
                    <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                        Whether I'm dissecting the latest tech trends, sharing coding tutorials, or reflecting on personal growth, my goal is to provide value, clarity, and a bit of inspiration to your day.
                    </p>
                    <div class="flex space-x-4">
                        <a href="#" class="w-10 h-10 rounded-full bg-white text-slate-600 flex items-center justify-center shadow-md hover:text-indigo-600 hover:-translate-y-1 transition-all"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-white text-slate-600 flex items-center justify-center shadow-md hover:text-indigo-600 hover:-translate-y-1 transition-all"><i class="fab fa-github"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-white text-slate-600 flex items-center justify-center shadow-md hover:text-indigo-600 hover:-translate-y-1 transition-all"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="mt-12 lg:mt-0 animate-on-scroll delay-200 relative">
                    <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-2xl transform rotate-3 opacity-20 blur-lg"></div>
                    <img class="relative rounded-2xl shadow-xl object-cover w-full h-[400px]" src="https://images.unsplash.com/photo-1517841905240-472988babdf9?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" alt="Person working">
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section id="newsletter" class="bg-indigo-700 py-16 sm:py-24 relative overflow-hidden">
        <!-- Abstract circles -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 rounded-full bg-indigo-600 opacity-50 blur-2xl"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-indigo-800 opacity-50 blur-2xl"></div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 shadow-2xl rounded-3xl bg-indigo-800 overflow-hidden border border-indigo-600/50">
             <div class="px-6 py-12 sm:px-12 sm:py-16 lg:flex lg:items-center lg:p-20">
                <div class="lg:w-0 lg:flex-1 animate-on-scroll">
                    <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
                        Want product news and updates?
                    </h2>
                    <p class="mt-4 max-w-3xl text-lg text-indigo-200">
                        Sign up for our newsletter to stay up to date. We promise not to spam.
                    </p>
                </div>
                <div class="mt-12 sm:w-full sm:max-w-md lg:mt-0 lg:ml-8 lg:flex-1 animate-on-scroll delay-200">
                    <form class="sm:flex">
                        <label for="email-address" class="sr-only">Email address</label>
                        <input id="email-address" name="email-address" type="email" autocomplete="email" required class="w-full border-white px-5 py-4 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-indigo-700 focus:ring-white rounded-xl text-slate-900 border" placeholder="Enter your email">
                        <button type="submit" class="mt-3 w-full flex items-center justify-center px-5 py-4 border border-transparent text-base font-medium rounded-xl text-white bg-indigo-500 hover:bg-indigo-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-indigo-700 focus:ring-white sm:mt-0 sm:ml-3 sm:w-auto sm:flex-shrink-0 transition-colors shadow-lg">
                            Notify me
                        </button>
                    </form>
                    <p class="mt-3 text-sm text-indigo-200">
                        We care about the protection of your data. Read our
                        <a href="#" class="text-white font-medium underline">Privacy Policy.</a>
                    </p>
                </div>
            </div>
        </div>
    </section>

  <%- include('partials/footer.ejs')  %>
